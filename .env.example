# Copy to .env on your VPS (and optionally locally for deploy.sh).
#   cp .env.example .env
#
# Never commit .env — it contains secrets.

# --- Minecraft server (read by compose.yaml on the VPS) ---

# Heap size passed to the JVM (image uses MEMORY / MAX_MEMORY, not MAX_RAM)
MAX_MEMORY=6G

# Required for CurseForge mod downloads (https://console.curseforge.com/)
CF_API_KEY=$2a$10$qfAlwbQSdfJiiCcNtaf.KOfpmz.b2JfIrGfQM9PU4VZ5oCrGUO9c2

# Change this after first boot (used for RCON / graceful commands)
RCON_PASSWORD=change_me_to_a_strong_password

# --- Local deploy.sh only (not used by Docker) ---

VPS_HOST=your.vps.ip.or.hostname
VPS_USER=root
VPS_PATH=/opt/minecraft-server

# Optional: Discord webhook URL for restart notifications
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional: set true to remove remote files not present in the repo during rsync
# DEPLOY_RSYNC_DELETE=false
